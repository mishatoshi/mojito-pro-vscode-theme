  "tokenColors": [
    {
      "name": "URL",
      "scope": [
        "*url*",
        "*link*",
        "*uri*"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.quoted.docstring"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#25744D"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "entity.name.variable",
        "variable.other punctuation.definition.variable"
      ],
      "settings": {
        "foreground": "#D5F6E3"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.other",
        "variable.readonly",
        "variable.other.constant",
        "variable.object",
        "variable.other.object",
        "support.constant",
        "support.other.variable",
        "variable.other.global",
        "variable.other.global punctuation.definition.variable"
      ],
      "settings": {
        "foreground": "#FFB74D"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#FF764D"
      }
    },
    {
